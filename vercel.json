{
  "rewrites": [
    { "source": "/api/docs", "destination": "/docs" },
    { "source": "/api/vessel-track", "destination": "/vessel-track" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
